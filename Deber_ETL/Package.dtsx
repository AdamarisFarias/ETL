                <property
                  dataType="System.String"
                  description="Comando SQL para ejecutar."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    f.IdCanalVenta, 
    CAST(MAX(ISNULL(cv.NombreCanal, 'No definido')) AS VARCHAR(50)) AS NombreCanal,
    CAST(MAX(ISNULL(fp.NombreFormaPago, 'No definido')) AS VARCHAR(40)) AS FormaPagoAsociada
FROM Factura f 
LEFT JOIN CanalVenta cv ON f.IdCanalVenta = cv.IdCanalVenta
LEFT JOIN FormaPago fp ON f.IdFormaPago = fp.IdFormaPago GROUP BY f.IdCanalVenta;</property>
                <property
