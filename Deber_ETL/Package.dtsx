                  dataType="System.String"
                  description="Comando SQL para ejecutar."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    
c.IdCliente, 
    
c.Cedula, 
    
(c.Nombres + ' ' + c.Apellidos) AS NombreCompleto, 
c.Sexo,
    
ISNULL(ci.NombreCiudad, 'No definido') AS NombreCiudad, 
    ISNULL(ci.Provincia, 'No definido') AS Provincia, 
    
ISNULL(ci.Region, 'No definido') AS Region

FROM Cliente c 

LEFT JOIN Ciudad ci ON c.IdCiudad = ci.IdCiudad;</property>
