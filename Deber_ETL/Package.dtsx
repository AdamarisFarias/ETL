                <property
                  dataType="System.String"
                  description="Comando SQL para ejecutar."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    CAST(FORMAT(Fecha, 'yyyyMMdd') AS INT) AS IdTiempo, 
    Fecha, 
    YEAR(Fecha) AS Anio,
    MONTH(Fecha) AS Mes,
    DATEPART(QUARTER, Fecha) AS Trimestre, 
    CAST(DATENAME(MONTH, Fecha) AS VARCHAR(20)) AS NombreMes, 
    DAY(Fecha) AS Dia,
    CAST(DATENAME(WEEKDAY, Fecha) AS VARCHAR(20)) AS DiaSemana,
    CAST(CASE WHEN DATEPART(WEEKDAY, Fecha) IN (6,7) THEN 'Sí' ELSE 'No' END AS VARCHAR(2)) AS EsFinDeSemana
FROM Factura 
GROUP BY Fecha;</property>
