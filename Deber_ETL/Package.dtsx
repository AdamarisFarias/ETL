                  dataType="System.String"
                  description="Comando SQL para ejecutar."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
df.IdDetalle AS IdVenta, 
CAST(FORMAT(f.Fecha, 'yyyyMMdd') AS INT) AS IdTiempo, 
f.IdCliente, 
df.IdProducto, 
f.IdEmpleado, 
f.IdCanalVenta, 
df.Cantidad, 
df.PrecioUnitario, 
df.Descuento, 
df.TotalLinea
FROM DetalleFactura df LEFT JOIN Factura f ON df.IdFactura = f.IdFactura;</property>
